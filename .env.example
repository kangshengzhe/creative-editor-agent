# LLM provider credentials & endpoint for the Creative Editor Agent.
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# API key for the DashScope / Alibaba Cloud Model Studio endpoint.
TOKENPONY_API_KEY=

# Base URL of the OpenAI-compatible chat-completions endpoint.
# Alibaba Cloud DashScope compatible-mode:
TOKENPONY_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model name served by the gateway.
# Recommended: qwen3.7-max  (flagship; fast with thinking disabled)
# Alternatives: qwen-plus (older, lighter), qwen3.6-plus
TOKENPONY_MODEL=qwen3.7-max

# Creative-generation sampling temperature (0.0–2.0, default 0.8).
# Only affects the ad-copy generation step; precision tasks keep their own
# lower temperatures. Raise for more creative diversity, lower for stability.
GENERATION_TEMPERATURE=0.8

# Enable deep-thinking / reasoning mode on the model (default false).
# New-generation models (Qwen3.x, DeepSeek V4) emit a long hidden <think>
# block before answering. With dozens of LLM calls per generation this adds
# several minutes of latency. Keep this false for ad-copy production.
ENABLE_THINKING=false
