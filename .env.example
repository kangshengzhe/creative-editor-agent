# LLM provider credentials & endpoint for the Creative Editor Agent.
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# API key for the TokenPony-compatible LLM gateway. Treat as a secret.
TOKENPONY_API_KEY=

# Base URL of the OpenAI-compatible chat-completions endpoint.
# Example: https://token-plan-cn.xiaomimimo.com/v1
TOKENPONY_BASE_URL=

# Model name served by the gateway.
# Example: mimo-v2.5-pro
TOKENPONY_MODEL=
